# EMR Backend Toggle — "local" or "medplum" (default: medplum)
EMR_BACKEND=local

# Clinical Database (required when EMR_BACKEND=local)
CLINICAL_DATABASE_URL="postgresql://xpc_emr:xpc_emr_dev_password@localhost:5432/xpc_emr_clinical"

# PhenoML SDK Configuration (required when EMR_BACKEND=medplum)
PHENOML_USERNAME=your_username
PHENOML_PASSWORD=your_password
PHENOML_BASE_URL=sign up at https://phenoml.com/

# FHIR Provider ID (get from PhenoML dashboard after configuring Medplum)
PHENOML_FHIR_PROVIDER_ID=your_provider_id

# FHIR Practitioner ID (the logged-in provider's Practitioner resource ID on Medplum)
NEXT_PUBLIC_FHIR_PRACTITIONER_ID=your_practitioner_id

# XPC Chart Review API
CHART_REVIEW_API_URL= contact XPC at https://platform.xprimarycare.com/
CHART_REVIEW_API_SECRET=your_chart_review_api_secret
NEXT_PUBLIC_PRACTITIONER_NAME=Your Name

# Google Vertex AI (Gemini 2.5 Flash)
# Also set GOOGLE_APPLICATION_CREDENTIALS env var to path of service account key JSON
# Or run: gcloud auth application-default login (for local dev)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# PostgreSQL (Docker Compose — run: docker compose up -d)
DATABASE_URL="postgresql://xpc_emr:xpc_emr_dev_password@localhost:5432/xpc_emr"

# Auth.js (generate secret with: npx auth secret)
AUTH_SECRET=your_auth_secret
AUTH_GOOGLE_ID=your_google_client_id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your_google_client_secret
